# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://zgaakmfzjonhewiletqc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: Admin invites (Dashboard → Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Browser: Google Maps JavaScript API (interactive spot map)
# Google Cloud → enable Maps JavaScript API → API key with HTTP referrer restriction
# (e.g. https://vacation-bice.vercel.app/* and http://localhost:3000/*)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server: Place Photos + optional Street View / Static Map for /api/map-preview
# Google Cloud → enable Places API (New) [and optionally Street View Static / Maps Static]
# Prefer a key restricted to server IPs / no HTTP referrer (or unrestricted for Vercel)
GOOGLE_MAPS_API_KEY=
